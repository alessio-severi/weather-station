<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.Hyperlink?>



<GridPane styleClass="root-pane" stylesheets="@styles.css"
          xmlns="http://javafx.com/javafx/25"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="it.chorax.graph.GraphController">
  <columnConstraints>
        <ColumnConstraints percentWidth="25" />
        <ColumnConstraints percentWidth="75" />
  </columnConstraints>
  <rowConstraints>
        <RowConstraints percentHeight="100" vgrow="ALWAYS" />
  </rowConstraints>
  <VBox styleClass="column-left-pane" GridPane.columnIndex="0">
    <!-- Riga alta: logo / titolo -->
    <HBox styleClass="sidebar-header">
      <ImageView
           fitWidth="120"
           preserveRatio="true"
           pickOnBounds="false">
        <image>
            <Image url="@../logo.png"/>
        </image>
      </ImageView>
    </HBox>

    <!-- Riga sotto: menu verticale -->
    <VBox styleClass="sidebar-menu">
      <Button  fx:id="aButton" styleClass="current-side-link, side-link-active" text="Temperature" />
      <Button  fx:id="bButton" onAction="#onMisureButton" styleClass="side-link" text="Pressure" />
      <Button  fx:id="cButton" onAction="#onMisureButton" styleClass="side-link" text="Relative Humidity" />
      <Button  fx:id="dButton" onAction="#onMisureButton" styleClass="side-link" text="Wind" />
      <Button  fx:id="eButton" onAction="#onMisureButton" styleClass="side-link" text="Precipitation">
        <VBox.margin>
          <Insets bottom="20.0" />
        </VBox.margin>
      </Button>
      <Button  fx:id="graphButton" styleClass="current-side-link" text="Graph" />
      <Button  onAction="#onWeather" styleClass="side-link" text="Weather" />
      <Button  onAction="#onConverter" styleClass="side-link" text="Unit Converter" />
      <Button  onAction="#onWorld" styleClass="side-link" text="Globe View" />
      <Button  styleClass="side-link" text="Exit" onAction="#onExit" />
    </VBox>
    <HBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS" styleClass="about-row">
      <Hyperlink onAction="#onAbout" styleClass="about-link" text="About &amp; Credits" />
    </HBox>
  </VBox>
  <VBox styleClass="column-right-pane" GridPane.columnIndex="1">
    <VBox styleClass="inner-pane">
      <!--
        Titolo principale.
        styleClass="title-label" ≈ class="title-label"
      -->
      <HBox alignment="CENTER">
        <Label alignment="CENTER_LEFT" styleClass="title-label" text="Graph">
          <HBox.margin>
            <Insets right="60.0" top="30.0" />
          </HBox.margin>
        </Label>
      </HBox>
      <!--
        Sottotitolo / descrizione breve.
      -->
      <Label styleClass="subtitle-label"
             text="Forecast charts of the main meteorological variables for the city selected in &quot;Weather&quot; section.&#10;Select an item in the menu on the left to change the chart.">
        <VBox.margin>
                  <Insets bottom="0" left="-5" right="-8" top="0" />
        </VBox.margin>
      </Label>

      
      <ScrollPane fitToWidth="true" styleClass="report-scroll">
        <content>
            <!-- Questa è la “cartolina” con bordo -->
            <VBox alignment="TOP_LEFT" styleClass="report-card">   <!-- larghezza massima della card -->
              <Label fx:id="cityLabel" styleClass="city-label"/>
            </VBox>
        </content>
      </ScrollPane>
      <ScrollPane fitToWidth="true" styleClass="report-scroll">
        <content>
            <!-- Questa è la “cartolina” con bordo -->
            <VBox fx:id="chartBox" alignment="TOP_CENTER" styleClass="report-card">   <!-- larghezza massima della card -->
             
            </VBox>
        </content>
      </ScrollPane>
      <ScrollPane fitToWidth="true" styleClass="report-scroll">
        <content>
            <!-- Questa è la “cartolina” con bordo -->
            <HBox fx:id="caseBox" alignment="TOP_CENTER" styleClass="report-card">   <!-- larghezza massima della card -->
              <Button fx:id="case0Button" onAction="#onChangeGraph0" styleClass="etch-button" text="Real">
                <HBox.margin>
                        <Insets bottom="0" left="0" right="10" top="0" />
                </HBox.margin>
              </Button>
              <Button fx:id="case1Button" onAction="#onChangeGraph1" styleClass="etch-button" text="Apparent">
                <HBox.margin>
                        <Insets bottom="0" left="10" right="0" top="0" />
                </HBox.margin>
              </Button>
            </HBox>
        </content>
      </ScrollPane>
      <HBox alignment="BOTTOM_RIGHT" styleClass="export-row">
        <Hyperlink text="Export" onAction="#onSaveChart" styleClass="export-link"/>
      </HBox>
    </VBox>
  </VBox>
</GridPane>
