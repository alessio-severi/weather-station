<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.Hyperlink?>



<GridPane styleClass="root-pane" stylesheets="@styles.css"
          xmlns="http://javafx.com/javafx/25"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="it.chorax.weather.WeatherController">
  <columnConstraints>
        <ColumnConstraints percentWidth="25" />
        <ColumnConstraints percentWidth="75" />
  </columnConstraints>
  <rowConstraints>
        <RowConstraints percentHeight="100" vgrow="ALWAYS" />
  </rowConstraints>
  <VBox styleClass="column-left-pane" GridPane.columnIndex="0">
    <!-- Riga alta: logo / titolo -->
    <HBox styleClass="sidebar-header">
      <ImageView
           fitWidth="120"
           preserveRatio="true"
           pickOnBounds="false">
        <image>
            <Image url="@../logo.png"/>
        </image>
      </ImageView>
    </HBox>

    <!-- Riga sotto: menu verticale -->
    <VBox styleClass="sidebar-menu">
      <Button  fx:id="weatherButton" styleClass="current-side-link" text="Weather" />
      <Button  fx:id="graphButton"  onAction="#onGraph" styleClass="side-link" text="Graph" />
      <Button  onAction="#onConverter" styleClass="side-link" text="Unit Converter" />
      <Button  onAction="#onWorld" styleClass="side-link" text="Globe View" />
      <Button  styleClass="side-link" text="Exit" onAction="#onExit" />
    </VBox>
    <HBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS" styleClass="about-row">
      <Hyperlink onAction="#onAbout" styleClass="about-link" text="About &amp; Credits" />
    </HBox>
  </VBox>
  <VBox styleClass="column-right-pane" GridPane.columnIndex="1">
    <VBox styleClass="inner-pane">
      <!--
        Titolo principale.
        styleClass="title-label" ≈ class="title-label"
      -->
      <HBox alignment="CENTER">
        <Label alignment="CENTER_LEFT" styleClass="title-label" text="Weather">
        <HBox.margin>
          <Insets right="60.0" top="30.0" />
        </HBox.margin></Label>
      </HBox>
      <!--
        Sottotitolo / descrizione breve.
      -->
      <Label fx:id="welcomeArea" styleClass="subtitle-label" text="">
        <VBox.margin>
                  <Insets bottom="-10" left="0" right="0" top="0" />
        </VBox.margin>
      </Label>

      <HBox alignment="CENTER" styleClass="row">
        
        <ComboBox fx:id="cityCombo" styleClass="unit-combo" />
        
        <Button onAction="#onFetchWeather" styleClass="etch-button" text="Get weather">
          <HBox.margin>
                  <Insets bottom="10.5" left="27" right="47" top="9.5" />
          </HBox.margin>
        </Button>
      </HBox>
      
      <ScrollPane fitToWidth="true" styleClass="report-scroll">
        <content>
            <!-- Questa è la “cartolina” con bordo -->
            <VBox fx:id="reportBox" alignment="TOP_LEFT" styleClass="report-card">   <!-- larghezza massima della card -->
              <Label fx:id="reportLabel" styleClass="report-text" />
            </VBox>
        </content>
      </ScrollPane>
      
    </VBox>
  </VBox>

</GridPane>
